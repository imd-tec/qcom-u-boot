if TARGET_IMDT_QCS8550

config SYS_BOARD
	default "imdt-qcs8550"

config SYS_VENDOR
	default "qualcomm"

config SYS_SOC
	default "efi"

config SYS_LDSCRIPT
	default "arch/arm/lib/elf_aarch64_efi.lds"

config IMDT_QCS8550_OVERLAYS
	string "Default DT overlay list"
	default ""
	help
	  Space-separated list of DT overlay filenames (relative to /dtb on
	  the EFI boot partition) applied to the base DTB at boot. The list
	  becomes the default value of the 'overlays' environment variable
	  and can be overridden at runtime with setenv.

endif
