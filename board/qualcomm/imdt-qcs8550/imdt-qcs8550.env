fdtfile=CONFIG_DEFAULT_FDT_FILE
fdt_addr=0xaf0000000
fdt_overlay_addr=0xaf1000000
loadaddr=0xae0000000
image=Image
overlays=CONFIG_IMDT_QCS8550_OVERLAYS
stdin=serial
stdout=serial,vidconsole
stderr=serial,vidconsole
bootargs=root=PARTLABEL=rootfs rw rootwait earlycon keep_bootcon ignore_loglevel loglevel=8
do_load_overlay=
	if load efi 0:2 ${fdt_overlay_addr} /dtb/${overlay};
	then
		fdt resize ${filesize};
		fdt apply ${fdt_overlay_addr};
	fi
do_apply_overlays=
	fdt addr ${fdt_addr};
	for overlay in ${overlays};
	do
		run do_load_overlay;
	done
do_boot=
	load efi 0:2 ${loadaddr} /${image};
	load efi 0:2 ${fdt_addr} /dtb/${fdtfile};
	run do_apply_overlays;
	booti ${loadaddr} - ${fdt_addr}
bootcmd=run do_boot
