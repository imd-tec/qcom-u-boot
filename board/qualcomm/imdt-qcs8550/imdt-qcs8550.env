fdtfile=CONFIG_DEFAULT_FDT_FILE
fdt_addr=0xaf0000000
loadaddr=0xae0000000
image=Image
stdin=serial
stdout=serial,vidconsole
stderr=serial,vidconsole
bootargs=root=PARTLABEL=rootfs rw rootwait earlycon keep_bootcon ignore_loglevel loglevel=8
do_boot=load efi 0:2 ${loadaddr} /${image}; load efi 0:2 ${fdt_addr} /dtb/${fdtfile}; booti ${loadaddr} - ${fdt_addr}
bootcmd=run do_boot
