fdt_addr=40000000
stdin=serial
stdout=serial,vidconsole
stderr=serial,vidconsole
bootargs=root=PARTLABEL=rootfs rw rootwait earlycon keep_bootcon ignore_loglevel loglevel=8
do_boot=load efi 0:2 0xae0000000 /Image; load efi 0:2 0xaf0000000 /dtb/qcs8550-imdt-sbc.dtb;booti 0xae0000000 - 0xaf0000000
bootcmd=run do_boot
