fdtfile=CONFIG_DEFAULT_FDT_FILE
fdt_addr=0xaf0000000
fdt_overlay_addr=0xaf1000000
loadaddr=0xae0000000
image=Image
rootfs_part=3
bootlimit=3
overlays=CONFIG_IMDT_QCS8550_OVERLAYS
stdin=serial
stdout=serial,vidconsole
stderr=serial,vidconsole
do_load_overlay=
	if load efi 0:${rootfs_part} ${fdt_overlay_addr} /boot/${overlay};
	then
		fdt resize ${filesize};
		fdt apply ${fdt_overlay_addr};
	fi
do_apply_overlays=
	fdt addr ${fdt_addr};
	for overlay in ${overlays};
	do
		run do_load_overlay;
	done
do_boot=
	setenv bootargs root=/dev/sda${rootfs_part} rw rootwait earlycon keep_bootcon ignore_loglevel loglevel=8;
	load efi 0:${rootfs_part} ${loadaddr} /boot/${image};
	load efi 0:${rootfs_part} ${fdt_addr} /boot/${fdtfile};
	run do_apply_overlays;
	booti ${loadaddr} - ${fdt_addr}
altbootcmd=
	if test ${rootfs_part} = 3;
	then
		setenv rootfs_part 4;
	else
		setenv rootfs_part 3;
	fi;
	setenv upgrade_available 0;
	setenv bootcount 0;
	saveenv;
	run do_boot
bootcmd=run do_boot
